From: builder <builder@localhost>
Subject: [PATCH] zynq: include TFTP boot environment settings

Include zynq-tftp-env.h which defines TFTP_ENV_SETTINGS macro
with network boot commands for the default U-Boot environment.

--- a/include/configs/zynq-common.h
+++ b/include/configs/zynq-common.h
@@ -169,6 +169,8 @@
 #include <config_distro_bootcmd.h>
 #endif /* CONFIG_SPL_BUILD */

+#include "zynq-tftp-env.h"
+
 /* Default environment */
 #ifndef CFG_EXTRA_ENV_SETTINGS
 #define CFG_EXTRA_ENV_SETTINGS	\
@@ -177,6 +179,7 @@
 	"pxefile_addr_r=0x2000000\0"    \
 	"kernel_addr_r=0x2000000\0"     \
 	"ramdisk_addr_r=0x3100000\0"    \
+	TFTP_ENV_SETTINGS \
 	BOOTENV
 #endif
